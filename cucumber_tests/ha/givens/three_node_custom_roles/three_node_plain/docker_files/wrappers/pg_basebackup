#!/usr/bin/env bash

set -euo pipefail

readonly BLOCKER_FILE="/var/lib/pgtuskmaster/faults/block-pg-basebackup"
readonly REAL_BIN="/usr/lib/postgresql/16/bin/pg_basebackup"

if [[ -f "${BLOCKER_FILE}" ]]; then
    printf 'pg_basebackup wrapper waiting for blocker removal: %s\n' "${BLOCKER_FILE}" >&2
    while [[ -f "${BLOCKER_FILE}" ]]; do
        sleep 1
    done
fi

exec "${REAL_BIN}" "$@"
