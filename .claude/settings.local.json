{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(while read f)",
      "Bash(do basename \"$f\")",
      "Bash(done)",
      "Bash({ grep -rl 'not_started' .)",
      "Bash(})",
      "Bash(xargs:*)",
      "Bash(make custom-lint:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(python:*)",
      "Bash(pip show:*)",
      "Bash(npx pyright:*)",
      "WebSearch",
      "Bash(dmesg:*)",
      "Bash(ps aux:*)",
      "Bash(npx biome check:*)",
      "Bash(/bin/bash:*)",
      "Bash(make test-behave:*)",
      "Bash(make check:*)",
      "Bash(make test:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/joshazimullah.linux/work_mounts/patroni_rewrite/pgtuskmaster/.claude/pretooluse-hook.sh"
          }
        ]
      }
    ]
  },
  "outputStyle": "default",
  "prefersReducedMotion": true
}
